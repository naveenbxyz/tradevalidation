# OpenAI / compatible endpoint
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_MODEL=gpt-4.1-mini
VERIFY_SSL=true
STREAM=false
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=120
LLM_SEND_IMAGES=false

# Local LLM (on-device inference engine, e.g. Qwen3-8B-MLX)
# Set LOCAL_LLM_ENABLED=true to use local model instead of the central LLM
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:8080/v1
LOCAL_LLM_MODEL=qwen3-8b-mlx-4bit
LOCAL_LLM_TIMEOUT=300
LOCAL_LLM_TEMPERATURE=0.0
LOCAL_LLM_MAX_TOKENS=4096

# App settings
DEBUG=true

# Paths (relative to backend/)
DATABASE_PATH=../data/database.json
UPLOAD_DIR=../data/uploads
INGEST_SCAN_DIR=../data/inbox
TRS_SCHEMA_PATH=app/schema_configs/trs_schema.json

# Validation controls
AUTO_PASS_THRESHOLD=0.85
MAX_FILE_SIZE=20971520
MAX_CONTENT_CHARS=50000
